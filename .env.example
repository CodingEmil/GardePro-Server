# GardePro Gallery — Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.

# ── Pfade (Docker) ────────────────────────────────────────
# Verzeichnis für heruntergeladene Medien (Fotos/Videos)
# ARCHIVE_DIR=/data/archive

# Verzeichnis für Datenbank und State-Dateien
# DATA_DIR=/data

# Zeitzone
TZ=Europe/Berlin

# ── Kamera ────────────────────────────────────────────────
# CAMERA_IP=192.168.8.1
# CAMERA_PORT=8080
# SYNC_INTERVAL_MINUTES=30
# AUTO_SYNC_ENABLED=true

# ── Bluetooth & WLAN (nur nativ, nicht in Docker) ─────────
# BT_MAC_ADDRESS=AA:BB:CC:DD:EE:FF
# WIFI_SSID=
# WIFI_PASSWORD=
# WIFI_ADAPTER=

# ── Immich Integration ────────────────────────────────────
# IMMICH_ENABLED=false
# IMMICH_SERVER_URL=http://localhost:2283
# IMMICH_API_KEY=
# IMMICH_ALBUM_NAME=GardePro Wildkamera
